# ─── Base de Datos ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://realestate_user:password@localhost:5432/realestate_pro

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=cambia-esto-en-produccion
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Wompi (Colombia) ─────────────────────────────────────────────────────────
# Obtén tus claves en: https://comercios.wompi.co
WOMPI_ENV=sandbox                          # sandbox | production
WOMPI_PUBLIC_KEY=pub_stagtest_...          # empieza con pub_stagtest_ (sandbox) o pub_prod_ (produccion)
WOMPI_PRIVATE_KEY=prv_stagtest_...         # empieza con prv_stagtest_ (sandbox) o prv_prod_ (produccion)
WOMPI_EVENTS_SECRET=stagtest_events_...    # para verificar webhooks

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ─── URLs ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Cross Portal SSO (.com ↔ .info) ─────────────────────────────────────────
# Mismo valor en AMBOS backends — genera uno con: python3 -c "import secrets; print(secrets.token_hex(32))"
CROSS_PORTAL_SECRET=genera-un-secreto-largo-aqui

# URL del backend de .info (para cross-register)
INFO_PORTAL_API_URL=https://api.velezyricaurte.info

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Para Gmail: activa "Contraseñas de aplicación" en tu cuenta Google
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=johnroa@velezyricaurte.com
SMTP_PASSWORD=tu-contrasena-de-aplicacion-gmail
EMAIL_FROM=VelezyRicaurte Inmobiliaria <johnroa@velezyricaurte.com>
